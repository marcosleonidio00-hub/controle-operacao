modules = ["nodejs-24", "postgresql-16"]

[run]
command = "node artifacts/api-server/dist/index.js"

[deployment]
run = "node artifacts/api-server/dist/index.js"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 21384
externalPort = 3000
